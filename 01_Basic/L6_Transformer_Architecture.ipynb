        "## 🔧 Part 2: Feed-Forward Networks\n",
        "\n",
        "**Feed-Forward Networks (FFN)** process each position independently after attention.\n",
        "\n",
        "### Structure:\n",
        "```\n",
        "Input → Linear → ReLU → Linear → Output\n",
        "```\n",
        "\n",
        "### Key Points:\n",
        "- Applied to each position separately\n",
        "- Typically expands dimension (d_model → 4*d_model → d_model)\n",
        "- Adds non-linearity and processing capacity\n",
        "\n",
        "---"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Step 4: Implement Feed-Forward Network\n",
        "\n",
        "class FeedForward(nn.Module):\n",
        "    \"\"\"\n",
        "    Position-wise Feed-Forward Network.\n",
        "    \n",
        "    Args:\n",
        "        d_model: Model dimension\n",
        "        d_ff: Hidden dimension (typically 4 * d_model)\n",
        "        dropout: Dropout rate\n",
        "    \"\"\"\n",
        "    def __init__(self, d_model, d_ff, dropout=0.1):\n",
        "        super(FeedForward, self).__init__()\n",
        "        self.linear1 = nn.Linear(d_model, d_ff)\n",
        "        self.dropout = nn.Dropout(dropout)\n",
        "        self.linear2 = nn.Linear(d_ff, d_model)\n",
        "    \n",
        "    def forward(self, x):\n",
        "        \"\"\"\n",
        "        Forward pass: Linear → ReLU → Dropout → Linear\n",
        "        \n",
        "        Args:\n",
        "            x: Input tensor (batch_size, seq_len, d_model)\n",
        "        \n",
        "        Returns:\n",
        "            output: Processed tensor (batch_size, seq_len, d_model)\n",
        "        \"\"\"\n",
        "        # First linear layer with ReLU activation\n",
        "        x = F.relu(self.linear1(x))\n",
        "        \n",
        "        # Dropout for regularization\n",
        "        x = self.dropout(x)\n",
        "        \n",
        "        # Second linear layer\n",
        "        x = self.linear2(x)\n",
        "        \n",
        "        return x\n",
        "\n",
        "# Test Feed-Forward Network\n",
        "d_ff = 2048  # Typically 4 * d_model\n",
        "ffn = FeedForward(d_model, d_ff)\n",
        "\n",
        "x_test = torch.randn(batch_size, seq_len, d_model)\n",
        "output_ffn = ffn(x_test)\n",
        "\n",
        "print(\"✅ Feed-Forward Network Test:\")\n",
        "print(f\"Input shape: {x_test.shape}\")\n",
        "print(f\"Hidden dimension: {d_ff}\")\n",
        "print(f\"Output shape: {output_ffn.shape}\")\n",
        "print(f\"\\n💡 FFN expands to {d_ff} dimensions internally, then projects back to {d_model}\")"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 🔗 Part 3: Layer Normalization and Residual Connections\n",
        "\n",
        "**Layer Normalization** stabilizes training by normalizing activations.\n",
        "**Residual Connections** allow gradients to flow directly through the network.\n",
        "\n",
        "### Why They Matter:\n",
        "- **Layer Norm:** Prevents internal covariate shift\n",
        "- **Residual:** Enables training of very deep networks\n",
        "- **Together:** Make transformers trainable at scale\n",
        "\n",
        "### Formula:\n",
        "```\n",
        "Output = LayerNorm(x + Sublayer(x))\n",
        "```\n",
        "\n",
        "---"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Step 5: Implement Layer Normalization with Residual Connection\n",
        "\n",
        "class ResidualConnection(nn.Module):\n",
        "    \"\"\"\n",
        "    Residual connection with layer normalization.\n",
        "    Implements: LayerNorm(x + Sublayer(x))\n",
        "    \n",
        "    Args:\n",
        "        d_model: Model dimension\n",
        "        dropout: Dropout rate\n",
        "    \"\"\"\n",
        "    def __init__(self, d_model, dropout=0.1):\n",
        "        super(ResidualConnection, self).__init__()\n",
        "        self.norm = nn.LayerNorm(d_model)\n",
        "        self.dropout = nn.Dropout(dropout)\n",
        "    \n",
        "    def forward(self, x, sublayer):\n",
        "        \"\"\"\n",
        "        Apply residual connection to any sublayer.\n",
        "        \n",
        "        Args:\n",
        "            x: Input tensor\n",
        "            sublayer: Function to apply (attention or feed-forward)\n",
        "        \n",
        "        Returns:\n",
        "            output: x + sublayer(LayerNorm(x))\n",
        "        \"\"\"\n",
        "        # Pre-norm variant: Norm → Sublayer → Dropout → Residual\n",
        "        return x + self.dropout(sublayer(self.norm(x)))\n",
        "\n",
        "# Test Residual Connection\n",
        "residual = ResidualConnection(d_model)\n",
        "x_test = torch.randn(batch_size, seq_len, d_model)\n",
        "\n",
        "# Define a simple sublayer (identity function for testing)\n",
        "def identity_sublayer(x):\n",
        "    return x * 0.1  # Small modification\n",
        "\n",
        "output_residual = residual(x_test, identity_sublayer)\n",
        "\n",
        "print(\"✅ Residual Connection Test:\")\n",
        "print(f\"Input shape: {x_test.shape}\")\n",
        "print(f\"Output shape: {output_residual.shape}\")\n",
        "print(f\"\\n💡 Residual connections help gradients flow through deep networks\")\n",
        "print(f\"   Original input is preserved and added to the sublayer output\")"
      ]
    }
