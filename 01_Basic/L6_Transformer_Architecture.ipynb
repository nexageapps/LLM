        "## 🏗️ Part 4: Encoder Block\n",
        "\n",
        "An **Encoder Block** combines all the components we've built:\n",
        "\n",
        "### Structure:\n",
        "```\n",
        "Input\n",
        "  ↓\n",
        "Multi-Head Attention + Residual + LayerNorm\n",
        "  ↓\n",
        "Feed-Forward + Residual + LayerNorm\n",
        "  ↓\n",
        "Output\n",
        "```\n",
        "\n",
        "---"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Step 6: Implement Encoder Block\n",
        "\n",
        "class EncoderBlock(nn.Module):\n",
        "    \"\"\"\n",
        "    Single Transformer Encoder Block.\n",
        "    \n",
        "    Args:\n",
        "        d_model: Model dimension\n",
        "        num_heads: Number of attention heads\n",
        "        d_ff: Feed-forward hidden dimension\n",
        "        dropout: Dropout rate\n",
        "    \"\"\"\n",
        "    def __init__(self, d_model, num_heads, d_ff, dropout=0.1):\n",
        "        super(EncoderBlock, self).__init__()\n",
        "        \n",
        "        # Multi-head self-attention\n",
        "        self.attention = MultiHeadAttention(d_model, num_heads)\n",
        "        \n",
        "        # Feed-forward network\n",
        "        self.feed_forward = FeedForward(d_model, d_ff, dropout)\n",
        "        \n",
        "        # Residual connections\n",
        "        self.residual1 = ResidualConnection(d_model, dropout)\n",
        "        self.residual2 = ResidualConnection(d_model, dropout)\n",
        "    \n",
        "    def forward(self, x, mask=None):\n",
        "        \"\"\"\n",
        "        Forward pass through encoder block.\n",
        "        \n",
        "        Args:\n",
        "            x: Input tensor (batch_size, seq_len, d_model)\n",
        "            mask: Optional attention mask\n",
        "        \n",
        "        Returns:\n",
        "            output: Encoded tensor (batch_size, seq_len, d_model)\n",
        "        \"\"\"\n",
        "        # Self-attention with residual connection\n",
        "        x = self.residual1(x, lambda x: self.attention(x, x, x, mask))\n",
        "        \n",
        "        # Feed-forward with residual connection\n",
        "        x = self.residual2(x, self.feed_forward)\n",
        "        \n",
        "        return x\n",
        "\n",
        "# Test Encoder Block\n",
        "encoder_block = EncoderBlock(d_model, num_heads, d_ff)\n",
        "x_test = torch.randn(batch_size, seq_len, d_model)\n",
        "\n",
        "output_encoder = encoder_block(x_test)\n",
        "\n",
        "print(\"✅ Encoder Block Test:\")\n",
        "print(f\"Input shape: {x_test.shape}\")\n",
        "print(f\"Output shape: {output_encoder.shape}\")\n",
        "print(f\"\\n🏗️ Encoder Block Components:\")\n",
        "print(f\"   1. Multi-Head Attention ({num_heads} heads)\")\n",
        "print(f\"   2. Residual Connection + Layer Norm\")\n",
        "print(f\"   3. Feed-Forward Network (d_ff={d_ff})\")\n",
        "print(f\"   4. Residual Connection + Layer Norm\")"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 🎯 Part 5: Decoder Block\n",
        "\n",
        "A **Decoder Block** is similar to an encoder but includes:\n",
        "- **Masked Self-Attention:** Prevents looking at future tokens\n",
        "- **Cross-Attention:** Attends to encoder outputs\n",
        "\n",
        "### Structure:\n",
        "```\n",
        "Input\n",
        "  ↓\n",
        "Masked Self-Attention + Residual + LayerNorm\n",
        "  ↓\n",
        "Cross-Attention (with Encoder) + Residual + LayerNorm\n",
        "  ↓\n",
        "Feed-Forward + Residual + LayerNorm\n",
        "  ↓\n",
        "Output\n",
        "```\n",
        "\n",
        "---"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Step 7: Implement Decoder Block\n",
        "\n",
        "class DecoderBlock(nn.Module):\n",
        "    \"\"\"\n",
        "    Single Transformer Decoder Block.\n",
        "    \n",
        "    Args:\n",
        "        d_model: Model dimension\n",
        "        num_heads: Number of attention heads\n",
        "        d_ff: Feed-forward hidden dimension\n",
        "        dropout: Dropout rate\n",
        "    \"\"\"\n",
        "    def __init__(self, d_model, num_heads, d_ff, dropout=0.1):\n",
        "        super(DecoderBlock, self).__init__()\n",
        "        \n",
        "        # Masked self-attention\n",
        "        self.self_attention = MultiHeadAttention(d_model, num_heads)\n",
        "        \n",
        "        # Cross-attention (attends to encoder output)\n",
        "        self.cross_attention = MultiHeadAttention(d_model, num_heads)\n",
        "        \n",
        "        # Feed-forward network\n",
        "        self.feed_forward = FeedForward(d_model, d_ff, dropout)\n",
        "        \n",
        "        # Residual connections\n",
        "        self.residual1 = ResidualConnection(d_model, dropout)\n",
        "        self.residual2 = ResidualConnection(d_model, dropout)\n",
        "        self.residual3 = ResidualConnection(d_model, dropout)\n",
        "    \n",
        "    def forward(self, x, encoder_output, src_mask=None, tgt_mask=None):\n",
        "        \"\"\"\n",
        "        Forward pass through decoder block.\n",
        "        \n",
        "        Args:\n",
        "            x: Input tensor (batch_size, tgt_seq_len, d_model)\n",
        "            encoder_output: Encoder output (batch_size, src_seq_len, d_model)\n",
        "            src_mask: Source mask for encoder attention\n",
        "            tgt_mask: Target mask for self-attention (causal mask)\n",
        "        \n",
        "        Returns:\n",
        "            output: Decoded tensor (batch_size, tgt_seq_len, d_model)\n",
        "        \"\"\"\n",
        "        # Masked self-attention with residual connection\n",
        "        x = self.residual1(x, lambda x: self.self_attention(x, x, x, tgt_mask))\n",
        "        \n",
        "        # Cross-attention with encoder output\n",
        "        x = self.residual2(x, lambda x: self.cross_attention(x, encoder_output, encoder_output, src_mask))\n",
        "        \n",
        "        # Feed-forward with residual connection\n",
        "        x = self.residual3(x, self.feed_forward)\n",
        "        \n",
        "        return x\n",
        "\n",
        "# Test Decoder Block\n",
        "decoder_block = DecoderBlock(d_model, num_heads, d_ff)\n",
        "\n",
        "# Decoder input and encoder output\n",
        "x_decoder = torch.randn(batch_size, seq_len, d_model)\n",
        "encoder_out = torch.randn(batch_size, seq_len, d_model)\n",
        "\n",
        "output_decoder = decoder_block(x_decoder, encoder_out)\n",
        "\n",
        "print(\"✅ Decoder Block Test:\")\n",
        "print(f\"Decoder input shape: {x_decoder.shape}\")\n",
        "print(f\"Encoder output shape: {encoder_out.shape}\")\n",
        "print(f\"Decoder output shape: {output_decoder.shape}\")\n",
        "print(f\"\\n🎯 Decoder Block Components:\")\n",
        "print(f\"   1. Masked Self-Attention (prevents future peeking)\")\n",
        "print(f\"   2. Residual Connection + Layer Norm\")\n",
        "print(f\"   3. Cross-Attention (attends to encoder)\")\n",
        "print(f\"   4. Residual Connection + Layer Norm\")\n",
        "print(f\"   5. Feed-Forward Network\")\n",
        "print(f\"   6. Residual Connection + Layer Norm\")"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 🌟 Part 6: Complete Transformer\n",
        "\n",
        "Now let's build the complete Transformer by stacking encoder and decoder blocks.\n",
        "\n",
        "### Full Architecture:\n",
        "```\n",
        "Input Embedding + Positional Encoding\n",
        "  ↓\n",
        "N × Encoder Blocks\n",
        "  ↓\n",
        "Encoder Output\n",
        "  ↓\n",
        "Target Embedding + Positional Encoding\n",
        "  ↓\n",
        "N × Decoder Blocks (with Cross-Attention to Encoder)\n",
        "  ↓\n",
        "Linear + Softmax\n",
        "  ↓\n",
        "Output Probabilities\n",
        "```\n",
        "\n",
        "---"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Step 8: Implement Complete Transformer\n",
        "\n",
        "class Transformer(nn.Module):\n",
        "    \"\"\"\n",
        "    Complete Transformer model with encoder and decoder.\n",
        "    \n",
        "    Args:\n",
        "        src_vocab_size: Source vocabulary size\n",
        "        tgt_vocab_size: Target vocabulary size\n",
        "        d_model: Model dimension\n",
        "        num_heads: Number of attention heads\n",
        "        num_layers: Number of encoder/decoder layers\n",
        "        d_ff: Feed-forward hidden dimension\n",
        "        max_seq_len: Maximum sequence length\n",
        "        dropout: Dropout rate\n",
        "    \"\"\"\n",
        "    def __init__(self, src_vocab_size, tgt_vocab_size, d_model=512, num_heads=8, \n",
        "                 num_layers=6, d_ff=2048, max_seq_len=100, dropout=0.1):\n",
        "        super(Transformer, self).__init__()\n",
        "        \n",
        "        self.d_model = d_model\n",
        "        \n",
        "        # Embeddings\n",
        "        self.src_embedding = nn.Embedding(src_vocab_size, d_model)\n",
        "        self.tgt_embedding = nn.Embedding(tgt_vocab_size, d_model)\n",
        "        \n",
        "        # Positional encoding\n",
        "        self.pos_encoding = self.create_positional_encoding(max_seq_len, d_model)\n",
        "        \n",
        "        # Encoder layers\n",
        "        self.encoder_layers = nn.ModuleList([\n",
        "            EncoderBlock(d_model, num_heads, d_ff, dropout)\n",
        "            for _ in range(num_layers)\n",
        "        ])\n",
        "        \n",
        "        # Decoder layers\n",
        "        self.decoder_layers = nn.ModuleList([\n",
        "            DecoderBlock(d_model, num_heads, d_ff, dropout)\n",
        "            for _ in range(num_layers)\n",
        "        ])\n",
        "        \n",
        "        # Output projection\n",
        "        self.output_linear = nn.Linear(d_model, tgt_vocab_size)\n",
        "        \n",
        "        self.dropout = nn.Dropout(dropout)\n",
        "    \n",
        "    def create_positional_encoding(self, max_seq_len, d_model):\n",
        "        \"\"\"\n",
        "        Create positional encoding matrix.\n",
        "        \n",
        "        Args:\n",
        "            max_seq_len: Maximum sequence length\n",
        "            d_model: Model dimension\n",
        "        \n",
        "        Returns:\n",
        "            Positional encoding tensor (max_seq_len, d_model)\n",
        "        \"\"\"\n",
        "        pe = torch.zeros(max_seq_len, d_model)\n",
        "        position = torch.arange(0, max_seq_len, dtype=torch.float).unsqueeze(1)\n",
        "        div_term = torch.exp(torch.arange(0, d_model, 2).float() * (-math.log(10000.0) / d_model))\n",
        "        \n",
        "        pe[:, 0::2] = torch.sin(position * div_term)\n",
        "        pe[:, 1::2] = torch.cos(position * div_term)\n",
        "        \n",
        "        return pe.unsqueeze(0)  # (1, max_seq_len, d_model)\n",
        "    \n",
        "    def encode(self, src, src_mask=None):\n",
        "        \"\"\"\n",
        "        Encode source sequence.\n",
        "        \n",
        "        Args:\n",
        "            src: Source token IDs (batch_size, src_seq_len)\n",
        "            src_mask: Source mask\n",
        "        \n",
        "        Returns:\n",
        "            Encoder output (batch_size, src_seq_len, d_model)\n",
        "        \"\"\"\n",
        "        seq_len = src.size(1)\n",
        "        \n",
        "        # Embedding + positional encoding\n",
        "        x = self.src_embedding(src) * math.sqrt(self.d_model)\n",
        "        x = x + self.pos_encoding[:, :seq_len, :].to(x.device)\n",
        "        x = self.dropout(x)\n",
        "        \n",
        "        # Pass through encoder layers\n",
        "        for layer in self.encoder_layers:\n",
        "            x = layer(x, src_mask)\n",
        "        \n",
        "        return x\n",
        "    \n",
        "    def decode(self, tgt, encoder_output, src_mask=None, tgt_mask=None):\n",
        "        \"\"\"\n",
        "        Decode target sequence.\n",
        "        \n",
        "        Args:\n",
        "            tgt: Target token IDs (batch_size, tgt_seq_len)\n",
        "            encoder_output: Encoder output\n",
        "            src_mask: Source mask\n",
        "            tgt_mask: Target mask (causal)\n",
        "        \n",
        "        Returns:\n",
        "            Decoder output (batch_size, tgt_seq_len, d_model)\n",
        "        \"\"\"\n",
        "        seq_len = tgt.size(1)\n",
        "        \n",
        "        # Embedding + positional encoding\n",
        "        x = self.tgt_embedding(tgt) * math.sqrt(self.d_model)\n",
        "        x = x + self.pos_encoding[:, :seq_len, :].to(x.device)\n",
        "        x = self.dropout(x)\n",
        "        \n",
        "        # Pass through decoder layers\n",
        "        for layer in self.decoder_layers:\n",
        "            x = layer(x, encoder_output, src_mask, tgt_mask)\n",
        "        \n",
        "        return x\n",
        "    \n",
        "    def forward(self, src, tgt, src_mask=None, tgt_mask=None):\n",
        "        \"\"\"\n",
        "        Forward pass through complete transformer.\n",
        "        \n",
        "        Args:\n",
        "            src: Source token IDs (batch_size, src_seq_len)\n",
        "            tgt: Target token IDs (batch_size, tgt_seq_len)\n",
        "            src_mask: Source mask\n",
        "            tgt_mask: Target mask\n",
        "        \n",
        "        Returns:\n",
        "            Output logits (batch_size, tgt_seq_len, tgt_vocab_size)\n",
        "        \"\"\"\n",
        "        # Encode source\n",
        "        encoder_output = self.encode(src, src_mask)\n",
        "        \n",
        "        # Decode target\n",
        "        decoder_output = self.decode(tgt, encoder_output, src_mask, tgt_mask)\n",
        "        \n",
        "        # Project to vocabulary\n",
        "        output = self.output_linear(decoder_output)\n",
        "        \n",
        "        return output\n",
        "\n",
        "# Test Complete Transformer\n",
        "src_vocab_size = 10000\n",
        "tgt_vocab_size = 10000\n",
        "num_layers = 6\n",
        "\n",
        "transformer = Transformer(\n",
        "    src_vocab_size=src_vocab_size,\n",
        "    tgt_vocab_size=tgt_vocab_size,\n",
        "    d_model=d_model,\n",
        "    num_heads=num_heads,\n",
        "    num_layers=num_layers,\n",
        "    d_ff=d_ff\n",
        ")\n",
        "\n",
        "# Create sample input\n",
        "src = torch.randint(0, src_vocab_size, (batch_size, seq_len))\n",
        "tgt = torch.randint(0, tgt_vocab_size, (batch_size, seq_len))\n",
        "\n",
        "output = transformer(src, tgt)\n",
        "\n",
        "print(\"✅ Complete Transformer Test:\")\n",
        "print(f\"Source shape: {src.shape}\")\n",
        "print(f\"Target shape: {tgt.shape}\")\n",
        "print(f\"Output shape: {output.shape}\")\n",
        "print(f\"\\n🌟 Transformer Architecture:\")\n",
        "print(f\"   - Source vocabulary: {src_vocab_size:,}\")\n",
        "print(f\"   - Target vocabulary: {tgt_vocab_size:,}\")\n",
        "print(f\"   - Model dimension: {d_model}\")\n",
        "print(f\"   - Number of heads: {num_heads}\")\n",
        "print(f\"   - Number of layers: {num_layers}\")\n",
        "print(f\"   - Feed-forward dimension: {d_ff}\")\n",
        "print(f\"\\n📊 Model Statistics:\")\n",
        "total_params = sum(p.numel() for p in transformer.parameters())\n",
        "trainable_params = sum(p.numel() for p in transformer.parameters() if p.requires_grad)\n",
        "print(f\"   - Total parameters: {total_params:,}\")\n",
        "print(f\"   - Trainable parameters: {trainable_params:,}\")\n",
        "print(f\"   - Model size: ~{total_params * 4 / (1024**2):.2f} MB (float32)\")"
      ]
    }
